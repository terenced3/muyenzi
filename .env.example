NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
RESEND_API_KEY=your-resend-api-key

# Kiosk device authentication — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# Document signing HMAC — separate from APP_SECRET: rotating one must not break the other
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOCUMENT_SIGNING_SECRET=
